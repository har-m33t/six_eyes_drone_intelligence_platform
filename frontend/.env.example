# Frontend dev environment template. Copy to `.env.local` and fill in.
#
# VITE_MAPBOX_ACCESS_TOKEN lets the tactical map render under `npm run dev`
# without the Python dashboard server serving /runtime-config.js. Use a public
# Mapbox token (starts with `pk.`); restrict it by URL in your Mapbox account.
# Only VITE_-prefixed vars are exposed to the browser bundle.
VITE_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-public-token-here

# Claude Code — ignore all .claude folders anywhere in the tree
.claude/
**/.claude/

# Environment / secrets
.env
.env.*
!.env.example

# Python virtual environments
.venv/
venv/
env/

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Distribution / build
*.egg-info/
build/
dist/

# Footage (large binaries) and model weights — not committed
footage/*.mp4
*.pt
*.onnx

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

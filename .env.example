# Copy to .env and fill in real values. .env is gitignored.
FOUNDRY_URL=https://your-instance.palantirfoundry.com
FOUNDRY_TOKEN=your_bearer_token_here
MAPBOX_ACCESS_TOKEN=your_restricted_mapbox_public_token_here
TELEMENTRY_DATASET_RID=ri.foundry.main.dataset.your-dataset-rid
DETECTION_DATASET_RID=ri.foundry.main.dataset.your-dataset-rid
WS_HOST=localhost
WS_PORT=8765
DASHBOARD_HOST=localhost
DASHBOARD_PORT=8000
DASHBOARD_WS_URL=ws://localhost:8765
NAV_GEO_SPEED_DEG_S=0.00005
MISSION_DURATION_S=600

# Foundry sink is opt-in. Leave false to run the dashboard locally; set true
# only after filling in real FOUNDRY_URL / FOUNDRY_TOKEN / DATASET_RID above —
# otherwise every packet spawns a doomed request thread against the placeholder host.
FOUNDRY_ENABLED=false
